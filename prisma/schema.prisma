// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  hash           String
  firstName      String
  lastName       String
  isAuthor       Boolean   @default(false)
  isAdmin        Boolean   @default(false)
  posts          Post[]
  comments       Comment[] @relation("WrittenComments")
  liked_comments Comment[] @relation("LikedComments")
}

// Use @map and @@map options to adhere to naming conventions of snake case in databases and pascalCase and CamelCase in fields and models in prisma
model Post {
  id          Int       @id @default(autoincrement())
  publicId    String    @unique @default(uuid()) @map("public_id") @db.Uuid
  title       String
  text        String
  isPublished Boolean   @default(false) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  authorId    Int       @map("author_id")
  author      User      @relation(fields: [authorId], references: [id])
  comments    Comment[]

  @@map("posts")
}

model Comment {
  id          Int      @id @default(autoincrement())
  publicId    String   @unique @default(uuid()) @map("public_id") @db.Uuid
  text        String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  commenterId Int      @map("commenter_id")
  commenter   User     @relation("WrittenComments", fields: [commenterId], references: [id], onDelete: Cascade)
  postId      Int      @map("post_id")
  parent      Post     @relation(fields: [postId], references: [id])
  liked_by    User[]   @relation("LikedComments")
  likes       Int      @default(0)

  @@map("comments")
}
